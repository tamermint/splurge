// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  runtime  = "vercel-edge"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id              String        @unique @default(uuid())
  name            String
  email           String        @unique
  role            Role          @default(USER)
  emailVerified   DateTime?     @map("email_verified")
  plan            Plan          @default(FREE)
  paySchedule     PaySchedule?
  bills           Bill[]
  commitments     Commitment[]
  baselines       Baseline[]
  expenses        Expense[]
  splurgeGoals    SplurgeGoal[]
  buffer          Int
  startingBalance Int?
  accounts        Account[]
  sessions        Session[]

  @@map("users")
}

model Bill {
  id            String       @unique @default(uuid())
  name          String
  amount        Int
  dueDate       DateTime
  scheduleType  ScheduleType
  payRail       String
  payType       PayType
  deferredUntil DateTime?
  user          User         @relation(fields: [userId], references: [id])
  userId        String

  @@map("bills")
}

model Commitment {
  id               String     @unique @default(uuid())
  commitmentType   String
  commitmentAmount Int
  constraint       Constraint
  priority         Int
  user             User       @relation(fields: [userId], references: [id])
  userId           String

  @@map("commitments")
}

model Baseline {
  id     String @unique @default(uuid())
  name   String
  amount Int
  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@map("baselines")
}

model Expense {
  id     String   @unique @default(uuid())
  name   String
  amount Int
  date   DateTime
  user   User     @relation(fields: [userId], references: [id])
  userId String

  @@map("expenses")
}

model Inflow {
  id            String      @unique @default(uuid())
  amount        Int
  date          DateTime
  label         String
  paySchedule   PaySchedule @relation(fields: [payScheduleId], references: [id])
  payScheduleId String

  @@map("inflows")
}

model PaySchedule {
  id        String    @id @unique @default(uuid())
  frequency Frequency
  inflows   Inflow[]
  user      User      @relation(fields: [userId], references: [id])
  userId    String    @unique

  @@map("payschedules")
}

model SplurgeGoal {
  id              String          @id @unique @default(uuid())
  name            String
  goalType        SplurgeGoalType
  targetAmount    Int
  currentProgress Int
  priority        Int
  isAutoFunded    Boolean         @default(false)
  user            User            @relation(fields: [userId], references: [id])
  userId          String          @unique

  @@map("splurgegoals")
}

enum Role {
  USER
  ADMIN
}

enum SplurgeGoalType {
  asset
  experience
}

enum ScheduleType {
  weekly
  fortnightly
  monthly
  yearly
}

enum PayType {
  auto_debit @map("auto-debit")
  manual
}

enum Constraint {
  hard
  soft
}

enum Frequency {
  weekly
  fortnightly
  monthly
}

enum Plan {
  FREE
  PRO
}
